{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://factoria.local/schemas/autoplace.schema.json",
	"title": "Factoria Terrain Autoplace Rules",
	"type": "array",
	"items": {
		"type": "object",
		"additionalProperties": false,
		"required": ["terrain_id", "height_range", "moisture_range", "temperature_range", "base_score"],
		"properties": {
			"id": {
				"type": "string"
			},
			"terrain_id": {
				"$ref": "#/$defs/stable_id"
			},
			"height_range": {
				"$ref": "#/$defs/range"
			},
			"moisture_range": {
				"$ref": "#/$defs/range"
			},
			"temperature_range": {
				"$ref": "#/$defs/range"
			},
			"base_score": {
				"type": "number"
			},
			"height_weight": {
				"type": "number",
				"default": 1.0
			},
			"moisture_weight": {
				"type": "number",
				"default": 1.0
			},
			"temperature_weight": {
				"type": "number",
				"default": 1.0
			},
			"variation_weight": {
				"type": "number",
				"default": 0.0
			},
			"range_falloff": {
				"type": "number",
				"exclusiveMinimum": 0,
				"default": 0.25
			}
		}
	},
	"$defs": {
		"stable_id": {
			"type": "string",
			"pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$"
		},
		"range": {
			"type": "array",
			"minItems": 2,
			"maxItems": 2,
			"items": {
				"type": "number",
				"minimum": -1.0,
				"maximum": 1.0
			}
		}
	}
}
